<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 https://maven.apache.org/xsd/assembly-2.1.1.xsd">
  <id>gdal-suite</id>
  <formats>
    <format>zip</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>

  <dependencySets>
    <dependencySet>
      <useProjectArtifact>false</useProjectArtifact>
      <useTransitiveDependencies>false</useTransitiveDependencies>
      <outputDirectory>plugins/transforms/gdal-suite</outputDirectory>
      <scope>runtime</scope>
      <unpack>false</unpack>
      <includes>
        <include>ch.so.agi:hop-transform-ogr-reader</include>
        <include>ch.so.agi:hop-transform-ogr-exporter</include>
        <include>ch.so.agi:hop-transform-gdal-raster-info</include>
        <include>ch.so.agi:hop-transform-gdal-raster-convert</include>
        <include>ch.so.agi:hop-transform-gdal-raster-warp</include>
        <include>ch.so.agi:hop-transform-gdal-raster-buildvrt</include>
        <include>ch.so.agi:hop-transform-gdal-rasterize-vector</include>
      </includes>
    </dependencySet>
    <dependencySet>
      <useProjectArtifact>false</useProjectArtifact>
      <useTransitiveDependencies>true</useTransitiveDependencies>
      <outputDirectory>plugins/transforms/gdal-suite/lib</outputDirectory>
      <outputFileNameMapping>${artifact.artifactId}${dashClassifier?}.${artifact.extension}</outputFileNameMapping>
      <scope>runtime</scope>
      <unpack>false</unpack>
      <excludes>
        <exclude>ch.so.agi:hop-transform-ogr-reader</exclude>
        <exclude>ch.so.agi:hop-transform-ogr-exporter</exclude>
        <exclude>ch.so.agi:hop-transform-gdal-raster-info</exclude>
        <exclude>ch.so.agi:hop-transform-gdal-raster-convert</exclude>
        <exclude>ch.so.agi:hop-transform-gdal-raster-warp</exclude>
        <exclude>ch.so.agi:hop-transform-gdal-raster-buildvrt</exclude>
        <exclude>ch.so.agi:hop-transform-gdal-rasterize-vector</exclude>
      </excludes>
    </dependencySet>
  </dependencySets>
</assembly>
